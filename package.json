{
  "name": "groktask",
  "version": "0.1.0",
  "private": true,
  "description": "GrokTask — local Grok task runner with MCP, CLI, and native desktop UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"vite.config.ts\" \"tsconfig.json\" \"package.json\"",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"vite.config.ts\" \"tsconfig.json\" \"package.json\"",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"vite.config.ts\"",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:legacy": "node --test test/*.test.mjs",
    "ci:frontend": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "license": "MIT"
}
