{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for GrokTask GUI host windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "allow-settings-get",
    "allow-settings-set-tray-mode",
    "allow-settings-set-history-limit",
    "allow-settings-set-language",
    "allow-settings-set-theme",
    "allow-agents-status",
    "allow-agents-install",
    "allow-agents-remove",
    "allow-agents-workflow-enable",
    "allow-agents-workflow-disable",
    "allow-workspace-cwd",
    "allow-doctor-report",
    "allow-grok-cli-status",
    "allow-daemon-status-text",
    "allow-daemon-restart",
    "allow-tasks-list",
    "allow-tasks-show",
    "allow-tasks-send",
    "allow-history-clear"
  ]
}
